<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" spacing="30.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.FoodShare.ReceiverController">
    <padding>
        <Insets bottom="50.0" left="50.0" right="50.0" top="50.0"/>
    </padding>

    <Label fx:id="welcomeLabel" text="مرحباً">
        <font>
            <Font name="System Bold" size="32.0"/>
        </font>
    </Label>

    <Label text="صفحة المستفيد">
        <font>
            <Font size="18.0"/>
        </font>
    </Label>

    <VBox spacing="20.0" maxWidth="500.0">
        <VBox.margin>
            <Insets top="20.0"/>
        </VBox.margin>

        <Button text="عرض الوجبات المتاحة" onAction="#handleViewAvailableMeals" prefHeight="60.0" prefWidth="500.0"
                style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-size: 18px; -fx-cursor: hand;">
        </Button>

        <Button text="تسجيل الخروج" onAction="#handleLogout" prefHeight="50.0" prefWidth="500.0"
                style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-font-size: 16px; -fx-cursor: hand;">
            <VBox.margin>
                <Insets top="30.0"/>
            </VBox.margin>
        </Button>
    </VBox>
</VBox>