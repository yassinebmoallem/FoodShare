<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.FoodShare.MyMealsController">
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <Button text="← رجوع" onAction="#handleBack"
                style="-fx-background-color: #757575; -fx-text-fill: white; -fx-cursor: hand;">
            <font>
                <Font size="14.0"/>
            </font>
        </Button>

        <Region HBox.hgrow="ALWAYS"/>

        <Label text="وجباتي">
            <font>
                <Font name="System Bold" size="28.0"/>
            </font>
        </Label>

        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
        <VBox fx:id="mealsContainer" spacing="15.0">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
            </padding>
        </VBox>
    </ScrollPane>
</VBox>