<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" spacing="25.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.FoodShare.LoginController">
    <padding>
        <Insets bottom="50.0" left="50.0" right="50.0" top="50.0"/>
    </padding>

    <Label text="تسجيل الدخول">
        <font>
            <Font name="System Bold" size="32.0"/>
        </font>
    </Label>

    <VBox spacing="20.0" maxWidth="400.0">
        <VBox.margin>
            <Insets top="30.0"/>
        </VBox.margin>

        <VBox spacing="8.0">
            <Label text="البريد الإلكتروني">
                <font>
                    <Font size="14.0"/>
                </font>
            </Label>
            <TextField fx:id="emailField" promptText="أدخل بريدك الإلكتروني" prefHeight="40.0">
                <font>
                    <Font size="13.0"/>
                </font>
            </TextField>
        </VBox>

        <VBox spacing="8.0">
            <Label text="كلمة السر">
                <font>
                    <Font size="14.0"/>
                </font>
            </Label>
            <PasswordField fx:id="passwordField" promptText="أدخل كلمة السر" prefHeight="40.0">
                <font>
                    <Font size="13.0"/>
                </font>
            </PasswordField>
        </VBox>

        <Label fx:id="errorLabel" text="" textFill="RED" wrapText="true" minHeight="20.0">
            <font>
                <Font size="13.0"/>
            </font>
        </Label>

        <Button text="تسجيل الدخول" onAction="#handleLogin" prefHeight="45.0" prefWidth="400.0"
                style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-size: 15px; -fx-cursor: hand;">
            <VBox.margin>
                <Insets top="10.0"/>
            </VBox.margin>
        </Button>

        <Button text="إنشاء حساب جديد" onAction="#handleRegister" prefHeight="45.0" prefWidth="400.0"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 15px; -fx-cursor: hand;">
        </Button>
    </VBox>
</VBox>